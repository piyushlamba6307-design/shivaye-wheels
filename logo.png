<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Shivaye Wheels</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Poppins:wght@300;400;500&display=swap" rel="stylesheet">

<style>
body {margin:0;background:#000;color:#fff;font-family:'Poppins',sans-serif}

nav {
position:fixed;
width:100%;
display:flex;
justify-content:space-between;
align-items:center;
padding:20px 60px;
z-index:100;
background:rgba(0,0,0,0.6);
backdrop-filter:blur(10px);
}

.logo img {height:60px}

.menu a {
margin:0 15px;
text-decoration:none;
color:#fff;
}

.call-btn {
border:1px solid gold;
padding:8px 18px;
border-radius:25px;
}

.hero {
height:100vh;
background:url('https://images.unsplash.com/photo-1511919884226-fd3cad34687c') center/cover no-repeat;
display:flex;
align-items:center;
padding-left:80px;
background-color:rgba(0,0,0,0.75);
background-blend-mode:darken;
}

.hero h1 {
font-size:75px;
font-family:'Playfair Display',serif;
color:gold;
}

.btn {
padding:12px 28px;
border-radius:30px;
border:1px solid gold;
background:transparent;
color:#fff;
margin-right:10px;
}

.section {padding:100px 60px;text-align:center}
.section h2 {color:gold}

.cars {display:flex;justify-content:center;gap:25px;flex-wrap:wrap}
.card {
width:320px;
background:#111;
border-radius:12px;
overflow:hidden;
border:1px solid rgba(255,215,0,0.3);
}

.card img {width:100%;height:220px;object-fit:cover}
.card-content {padding:15px}
.price {color:gold}

.about {display:flex;align-items:center;padding:100px 60px}
.about img {width:50%}
.about-text {width:50%;padding:40px}

.contact {display:flex;padding:100px 60px}
.form,.info {flex:1}

input,textarea {
width:90%;padding:12px;margin:10px 0;background:#111;border:1px solid #333;color:white
}

.whatsapp {
position:fixed;bottom:20px;right:20px;background:#25D366;padding:16px;border-radius:50%
}

</style>
</head>

<body>

<nav>
<div class="logo">
<img src="logo.png" alt="logo">
</div>
<div class="menu">
<a href="#">Home</a>
<a href="#cars">Cars</a>
<a href="#about">About</a>
<a href="#contact">Contact</a>
<a href="tel:8830092400" class="call-btn">Call</a>
</div>
</nav>

<div class="hero">
<div>
<p>COMING SOON TO</p>
<h1>NAGPUR & RAIPUR</h1>
<p>Luxury Cars Destination</p>
<button class="btn">Explore Cars</button>
<button class="btn" onclick="window.location.href='tel:8830092400'">Call Now</button>
</div>
</div>

<div id="cars" class="section">
<h2>FEATURED CARS</h2>
<div class="cars">

<div class="card">
<img src="https://images.unsplash.com/photo-1605559424843-9e4c228bf1c2">
<div class="card-content">
<h3>Mercedes AMG GT</h3>
<p class="price">₹1.20 Cr</p>
<button class="btn">Enquire</button>
</div>
</div>

<div class="card">
<img src="https://images.unsplash.com/photo-1619767886558-efdc259cde1a">
<div class="card-content">
<h3>BMW M4</h3>
<p class="price">₹1.20 Cr</p>
<button class="btn">Enquire</button>
</div>
</div>

<div class="card">
<img src="https://images.unsplash.com/photo-1618843479313-40f8afb4b4d8">
<div class="card-content">
<h3>Porsche 911</h3>
<p class="price">₹1.20 Cr</p>
<button class="btn">Enquire</button>
</div>
</div>

</div>
</div>

<div id="about" class="about">
<img src="https://images.unsplash.com/photo-1549921296-3a6b9c4d4c0d">
<div class="about-text">
<h2>About Shivaye Wheels</h2>
<p>Premium luxury automobile marketplace offering verified vehicles.</p>
</div>
</div>

<div id="contact" class="contact">
<div class="form">
<h2>Contact Us</h2>
<input placeholder="Your Name">
<input placeholder="Phone Number">
<textarea placeholder="Message"></textarea>
<button class="btn">Send</button>
</div>

<div class="info">
<h2>Call or WhatsApp</h2>
<h1>8830092400</h1>
</div>
</div>

<a class="whatsapp" href="https://wa.me/918830092400">💬</a>

</body>
</html>
